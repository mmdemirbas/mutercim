{
  "$id": "https://github.com/mmdemirbas/mutercim/config/mutercim.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Configuration file for mutercim — Islamic scholarly book translation tool.",
  "properties": {
    "book": {
      "additionalProperties": false,
      "description": "Book metadata.",
      "properties": {
        "author": {
          "description": "Book author.",
          "type": "string"
        },
        "source_langs": {
          "default": [
            "ar"
          ],
          "description": "Source language codes (e.g. [\"ar\"]).",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "target_langs": {
          "default": [
            "tr"
          ],
          "description": "Target language codes (e.g. [\"tr\"]).",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "title": {
          "description": "Book title.",
          "type": "string"
        }
      },
      "type": "object"
    },
    "dpi": {
      "default": 300,
      "description": "DPI for PDF-to-image conversion.",
      "minimum": 72,
      "type": "integer"
    },
    "inputs": {
      "default": [
        {
          "path": "./input"
        }
      ],
      "description": "Input files with optional per-input page ranges.",
      "items": {
        "additionalProperties": false,
        "properties": {
          "pages": {
            "description": "Page range for this input (e.g. \"1-50\", \"1,5,10-20\", \"all\").",
            "type": "string"
          },
          "path": {
            "description": "Path to the input file (relative to workspace root).",
            "type": "string"
          }
        },
        "required": [
          "path"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "knowledge_dir": {
      "default": "./knowledge",
      "description": "Knowledge YAML files directory (relative to workspace root).",
      "type": "string"
    },
    "midstate_dir": {
      "default": "./midstate",
      "description": "Intermediate state directory (relative to workspace root).",
      "type": "string"
    },
    "output": {
      "default": "./output",
      "description": "Output directory (relative to workspace root).",
      "type": "string"
    },
    "rate_limit": {
      "additionalProperties": false,
      "description": "Rate limiting settings for API calls.",
      "properties": {
        "requests_per_minute": {
          "default": 14,
          "description": "Maximum requests per minute.",
          "minimum": 1,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "read": {
      "additionalProperties": false,
      "description": "Read phase (OCR/vision) settings.",
      "properties": {
        "concurrency": {
          "default": 1,
          "description": "Reserved for future parallel processing.",
          "minimum": 1,
          "type": "integer"
        },
        "models": {
          "description": "Ordered failover chain of models. First model is primary; on 429/quota exhaustion, fails over to next.",
          "items": {
            "additionalProperties": false,
            "properties": {
              "base_url": {
                "description": "Override base URL for OpenAI-compatible providers.",
                "type": "string"
              },
              "model": {
                "description": "Model name.",
                "type": "string"
              },
              "provider": {
                "description": "AI provider name.",
                "enum": [
                  "gemini",
                  "claude",
                  "openai",
                  "groq",
                  "mistral",
                  "openrouter",
                  "xai",
                  "ollama"
                ],
                "type": "string"
              },
              "rpm": {
                "description": "Requests per minute (0 = use provider default).",
                "type": "integer"
              },
              "vision": {}
            },
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "retry": {
      "additionalProperties": false,
      "description": "Retry settings for API calls.",
      "properties": {
        "backoff_seconds": {
          "default": 2,
          "description": "Base backoff duration in seconds (exponential: 2s, 4s, 8s).",
          "minimum": 1,
          "type": "integer"
        },
        "max_attempts": {
          "default": 3,
          "description": "Maximum number of retry attempts.",
          "minimum": 0,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "sections": {
      "default": [],
      "description": "Book section definitions. Pages not covered default to type: auto.",
      "items": {
        "additionalProperties": false,
        "properties": {
          "name": {
            "description": "Section name (for display/logging).",
            "type": "string"
          },
          "pages": {
            "description": "Page range (e.g. \"1-50\", \"1,5,10-20\").",
            "type": "string"
          },
          "translate": {
            "default": true,
            "description": "Whether to translate this section.",
            "type": "boolean"
          },
          "type": {
            "description": "Section layout type.",
            "enum": [
              "skip",
              "prose",
              "scholarly_entries",
              "reference_table",
              "toc",
              "index",
              "auto"
            ],
            "type": "string"
          }
        },
        "required": [
          "name",
          "pages",
          "type"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "translate": {
      "additionalProperties": false,
      "description": "Translation phase settings.",
      "properties": {
        "context_window": {
          "default": 2,
          "description": "Number of previous pages to include as context.",
          "minimum": 0,
          "type": "integer"
        },
        "models": {
          "description": "Ordered failover chain of models for translation.",
          "items": {
            "additionalProperties": false,
            "properties": {
              "base_url": {
                "description": "Override base URL for OpenAI-compatible providers.",
                "type": "string"
              },
              "model": {
                "description": "Model name.",
                "type": "string"
              },
              "provider": {
                "description": "AI provider name.",
                "enum": [
                  "gemini",
                  "claude",
                  "openai",
                  "groq",
                  "mistral",
                  "openrouter",
                  "xai",
                  "ollama"
                ],
                "type": "string"
              },
              "rpm": {
                "description": "Requests per minute (0 = use provider default).",
                "type": "integer"
              },
              "vision": {}
            },
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "write": {
      "additionalProperties": false,
      "description": "Write/compilation phase settings.",
      "properties": {
        "expand_sources": {
          "default": true,
          "description": "Expand source abbreviations in output.",
          "type": "boolean"
        },
        "formats": {
          "default": [
            "md",
            "latex"
          ],
          "description": "Output formats to generate.",
          "items": {
            "enum": [
              "md",
              "latex",
              "docx"
            ],
            "type": "string"
          },
          "type": "array"
        },
        "latex_docker_image": {
          "default": "mutercim/xelatex:latest",
          "description": "Docker image for LaTeX/PDF compilation.",
          "type": "string"
        },
        "skip_pdf": {
          "default": false,
          "description": "Skip PDF compilation from LaTeX.",
          "type": "boolean"
        }
      },
      "type": "object"
    }
  },
  "title": "mutercim configuration",
  "type": "object"
}
